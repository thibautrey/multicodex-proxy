{
  "name": "multivibe",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch --import ./src/instrument.ts src/server.ts",
    "build:api": "tsc -p tsconfig.json",
    "build:web": "npm --prefix web run build",
    "build": "npm run build:web && npm run build:api",
    "start": "node --import ./dist/instrument.js dist/server.js"
  },
  "dependencies": {
    "@foxglove/wasm-zstd": "^1.0.1",
    "@sentry/node": "^9.47.1",
    "@types/ws": "^8.18.1",
    "body-parser": "^1.20.4",
    "express": "^4.22.1",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
